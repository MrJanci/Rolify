# ===========================================
# Rolify — Infrastructure Environment Variables
# Kopieren als `.env` und Werte einsetzen
# ===========================================

# --- Postgres ---
PG_PASSWORD=change_me_in_prod
DATABASE_URL=postgres://postgres:change_me_in_prod@postgres:5432/rolify

# --- Redis ---
REDIS_PASSWORD=change_me_in_prod
REDIS_URL=redis://:change_me_in_prod@redis:6379

# --- MinIO (S3-kompatibel) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_in_prod
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://cdn.rolify.ch
MINIO_BUCKET_TRACKS=tracks
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_AVATARS=avatars

# --- Backend / Fastify ---
NODE_ENV=development
PORT=3000
JWT_SECRET=generate_via_openssl_rand_hex_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:3000

# --- Spotify Web API (fuer Metadata-Harvester) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Stripe [Phase 2 — initial leer] ---
# STRIPE_SECRET=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID_MONTHLY=price_xxx
# STRIPE_PRICE_ID_YEARLY=price_xxx
