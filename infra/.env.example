# ===========================================
# Rolify — Infrastructure Environment Variables
# Kopieren als `.env` und Werte einsetzen
# ===========================================

# --- Postgres ---
PG_PASSWORD=change_me_in_prod
DATABASE_URL=postgres://postgres:change_me_in_prod@postgres:5432/rolify

# --- Redis ---
REDIS_PASSWORD=change_me_in_prod
REDIS_URL=redis://:change_me_in_prod@redis:6379

# --- MinIO (S3-kompatibel) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_in_prod
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://cdn.rolify.ch
MINIO_BUCKET_TRACKS=tracks
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_AVATARS=avatars

# --- Backend / Fastify ---
NODE_ENV=development
PORT=3000
JWT_SECRET=generate_via_openssl_rand_hex_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:3000

# --- Spotify Web API (fuer Metadata-Harvester) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Last.fm API (fuer Dynamic Auto-Playlists) ---
# Kostenloser API-Key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ===========================================
# === Container-Ressourcen-Profile ===
# Defaults sind fuer Pi 4 (4GB) tuned. Hochsetzen je nach Hardware.
# ===========================================
#
# === Pi 4 (4GB RAM, 4 cores @ 1.5GHz) ===
# Total budget: ~3.4G RAM / ~3.5 cores (Rest fuer System)
# Scraper:   DOWNLOAD=4  TRANSCODE=2  CPU=1.5  MEM=1500M
# Backend:   CPU=1.0  MEM=768M    (768M weil v0.18 /browse/home 7-parallel queries)
# Postgres:  CPU=0.75  MEM=512M
# Redis:     CPU=0.5  MEM=256M
# MinIO:     CPU=0.75  MEM=512M
# Anisette:  CPU=0.3  MEM=256M
# Nginx:     CPU=0.5  MEM=128M
#
# === Pi 5 (8GB RAM, 4 cores @ 2.4GHz) ===
# Total budget: ~7G RAM / ~3.5 cores
# Scraper:   DOWNLOAD=6  TRANSCODE=3  CPU=2.5  MEM=2500M
# Backend:   CPU=1.5  MEM=1024M
# Postgres:  CPU=1.0  MEM=1024M
# Redis:     CPU=0.5  MEM=512M
# MinIO:     CPU=1.0  MEM=1024M
# Anisette:  CPU=0.3  MEM=256M
#
# === x86-Server (16GB+ / 4+ cores) ===
# Limits ggf. komplett rausnehmen oder grosszuegig:
# Scraper:   DOWNLOAD=12 TRANSCODE=4  CPU=3.0  MEM=4G
# Backend:   CPU=2.0  MEM=2G
# Postgres:  CPU=2.0  MEM=2G
# Redis:     CPU=1.0  MEM=1G
# MinIO:     CPU=2.0  MEM=2G

CONCURRENCY_DOWNLOAD=4
CONCURRENCY_TRANSCODE=2

SCRAPER_CPU_LIMIT=1.5
SCRAPER_MEM_LIMIT=1500M

BACKEND_CPU_LIMIT=1.0
BACKEND_MEM_LIMIT=768M

POSTGRES_CPU_LIMIT=0.75
POSTGRES_MEM_LIMIT=512M

REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=256M

MINIO_CPU_LIMIT=0.75
MINIO_MEM_LIMIT=512M

# Prisma-Connection-Pool. Default 20 = passt fuer 2-3 concurrent users
# auf Pi mit /browse/home 7-parallel-queries. Auf x86 ggf. 50.
PRISMA_CONNECTION_LIMIT=20

# --- Stripe [Phase 2 — initial leer] ---
# STRIPE_SECRET=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID_MONTHLY=price_xxx
