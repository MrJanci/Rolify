// Rolify Prisma Schema
// Generiert Client nach `pnpm prisma generate`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  displayName        String
  avatarUrl          String?
  bio                String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // [Phase 2] Payments — initial ACTIVE per Default
  stripeCustomerId   String?    @unique
  subscriptionStatus SubStatus  @default(ACTIVE)
  subscriptionEndsAt DateTime?

  playlists          Playlist[]
  library            LibraryTrack[]
  savedAlbums        SavedAlbum[]
  savedArtists       SavedArtist[]
  offlineLicenses    OfflineLicense[]
  sessions           Session[]
  jamSessions        JamSession[]           @relation("JamHost")
  jamParticipations  JamParticipant[]
  playlistCollabs    PlaylistCollaborator[]
  playlistSettings   UserPlaylistSettings[]
}

model Artist {
  id       String   @id @default(cuid())
  name     String   @unique
  imageUrl String?
  albums   Album[]
  tracks   Track[]
  savedBy  SavedArtist[]
}

model Album {
  id          String   @id
  title       String
  coverUrl    String
  releaseYear Int
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id])
  tracks      Track[]
  savedBy     SavedAlbum[]

  @@index([artistId])
}

model Track {
  id               String   @id @default(cuid())
  title            String
  durationMs       Int
  trackNumber      Int
  isrc             String?  @unique
  spotifyId        String?  @unique
  albumId          String
  album            Album    @relation(fields: [albumId], references: [id])
  artistId         String
  artist           Artist   @relation(fields: [artistId], references: [id])
  encryptedBlobKey String
  masterKey        Bytes
  createdAt        DateTime @default(now())

  playlistTracks   PlaylistTrack[]
  libraryEntries   LibraryTrack[]
  offlineLicenses  OfflineLicense[]
  jamSessions      JamSession[]     @relation("JamCurrentTrack")
  lyrics           Lyrics?

  @@index([title])
  @@index([artistId])
  @@index([albumId])
}

// Lyrics-Cache via LRClib (gratis Time-Synced-Lyrics-API).
// One-per-Track (1:1 Relation). Lazy-fetched bei erstem GET /tracks/:id/lyrics.
model Lyrics {
  trackId   String   @id
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  lrcSynced String?  // LRC-Format mit timestamps "[mm:ss.xx]text"
  plain     String?  // plain-text fallback (kein time-sync)
  source    String   @default("lrclib") // "lrclib" / "manual" / "none"
  cachedAt  DateTime @default(now())

  @@index([cachedAt])
}

model Playlist {
  id            String                 @id @default(cuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  coverUrl      String?
  description   String?
  isPublic      Boolean                @default(false)
  // Collaborative-Playlist: wenn true, duerfen alle in `collaborators` writen
  isCollaborative Boolean              @default(false)
  // Mixed-Playlist: regeneriert sich taeglich (KI/Algo)
  isMixed       Boolean                @default(false)
  mixSeedId     String?                // Seed-Artist/Track fuer Mix-Algo
  // Dynamic-Playlist (Auto-aktualisiert aus externer Quelle)
  isDynamic     Boolean                @default(false)
  dynamicSource String?                @unique // "lastfm:global:daily" / "tiktok:trending:de" / etc.
  rotationMode  String                 @default("rotate") // "rotate" | "accumulate"
  refreshIntervalH Int                 @default(24)
  lastRefreshedAt DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  tracks        PlaylistTrack[]
  collaborators PlaylistCollaborator[]

  @@index([userId])
  @@index([isDynamic])
}

// Pro-User Toggle ob eine Dynamic-Playlist (global) in seiner Library sichtbar ist.
// Dynamic-Playlists existieren GLOBAL (1× pro source), per-user wird nur sichtbarkeit gesteuert.
model UserPlaylistSettings {
  userId  String
  source  String  // matched gegen Playlist.dynamicSource
  enabled Boolean @default(true)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, source])
  @@index([source])
}

model PlaylistCollaborator {
  playlistId String
  userId     String
  role       CollabRole @default(EDITOR)
  addedAt    DateTime   @default(now())
  playlist   Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([playlistId, userId])
  @@index([userId])
}

enum CollabRole {
  EDITOR
  VIEWER
}

model PlaylistTrack {
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id])

  @@id([playlistId, trackId])
  @@index([playlistId, position])
}

model LibraryTrack {
  userId  String
  trackId String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track   Track    @relation(fields: [trackId], references: [id])

  @@id([userId, trackId])
  @@index([userId, savedAt])
}

model SavedAlbum {
  userId  String
  albumId String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album   Album    @relation(fields: [albumId], references: [id])

  @@id([userId, albumId])
  @@index([userId, savedAt])
}

model SavedArtist {
  userId   String
  artistId String
  savedAt  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist   Artist   @relation(fields: [artistId], references: [id])

  @@id([userId, artistId])
  @@index([userId, savedAt])
}

model OfflineLicense {
  id           String   @id @default(cuid())
  userId       String
  trackId      String
  encryptedKey Bytes
  issuedAt     DateTime @default(now())
  expiresAt    DateTime
  deviceId     String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track        Track    @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId, deviceId])
  @@index([expiresAt])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  devicePubKey     Bytes?
  refreshTokenHash String   @unique
  userAgent        String?
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JamSession {
  id                String    @id @default(cuid())
  hostUserId        String
  host              User      @relation("JamHost", fields: [hostUserId], references: [id])
  code              String    @unique
  name              String?
  createdAt         DateTime  @default(now())
  endedAt           DateTime?
  // Aktuelle Playback-Position fuer late-joiners
  currentTrackId    String?
  currentTrack      Track?    @relation("JamCurrentTrack", fields: [currentTrackId], references: [id])
  isPaused          Boolean   @default(false)
  positionMs        Int       @default(0)
  positionUpdatedAt DateTime  @default(now())

  participants      JamParticipant[]

  @@index([code])
}

model JamParticipant {
  sessionId String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  session   JamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@index([sessionId])
}

model ScrapeJob {
  id               String        @id @default(cuid())
  playlistUrl      String
  status           ScrapeStatus  @default(QUEUED)
  totalTracks      Int           @default(0)
  processedTracks  Int           @default(0)
  failedTracks     Int           @default(0)
  errorMessage     String?
  createdBy        String?       // userId des Initiators
  resultPlaylistId String?       // gesetzt nach Scrape wenn Worker eine Rolify-Playlist erzeugt hat
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  startedAt        DateTime?
  completedAt      DateTime?

  @@index([status, createdAt])
}

enum ScrapeStatus {
  QUEUED
  RUNNING
  PAUSED
  DONE
  FAILED
}

enum SubStatus {
  NONE
  ACTIVE
  PAST_DUE
  GRACE
  CANCELED
}
